# =============================================================================
# x-social-trader — configuration de référence
# =============================================================================
# Copier en `.env` (jamais commité, voir .gitignore) et remplir les valeurs.
# Les invariants en commentaires renvoient à CLAUDE.md §2.

# -----------------------------------------------------------------------------
# Mode de trading (INV-1 — double opt-in avant live)
# -----------------------------------------------------------------------------
# TRADING_MODE : paper | live
# PAPER_TRADING doit être `true` par défaut, toute bascule exige confirmation DB + UI.
TRADING_MODE=paper
PAPER_TRADING=true

# -----------------------------------------------------------------------------
# Kill switch global (INV-2) — 0 inactif, 1 actif
# -----------------------------------------------------------------------------
KILL_SWITCH=0

# -----------------------------------------------------------------------------
# Risk manager (INV-3) — limites par défaut
# -----------------------------------------------------------------------------
MAX_CAPITAL_USD=1000
MAX_POSITION_PCT=2
MAX_TOTAL_EXPOSURE_PCT=20
MAX_TRADES_PER_DAY=10
MAX_DAILY_DRAWDOWN_PCT=3
ALLOW_AFTER_HOURS=false

# -----------------------------------------------------------------------------
# Market calendar (RISK-01) — ISO 10383 MIC code
# -----------------------------------------------------------------------------
# XNYS = NYSE / US equities, XPAR = Euronext Paris (CAC 40),
# XLON = LSE, XETR = XETRA. Full list: exchange_calendars.get_calendar_names()
MARKET=XNYS

# -----------------------------------------------------------------------------
# Interactive Brokers (provider broker — phase 5)
# -----------------------------------------------------------------------------
IB_GATEWAY_URL=
IB_EXPECTED_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# twitterapi.io (provider social feed — phase 7)
# -----------------------------------------------------------------------------
TWITTERAPI_IO_KEY=
# Monthly hard cap (USD). Default = $45 ≈ $1.50/day × 30 — agreed in backlog.
TWITTERAPI_IO_MAX_USD=45
# Estimated cost per tweet event (twitterapi.io public tier ≈ $0.15 / 1k tweets).
# Tune once real invoices are available.
TWITTERAPI_IO_COST_PER_TWEET_USD=0.00015
TWITTERAPI_IO_BASE_URL=https://api.twitterapi.io
TWITTERAPI_IO_WS_URL=wss://ws.twitterapi.io/twitter/tweet/websocket

# -----------------------------------------------------------------------------
# LLM (endpoint OpenAI-compatible — phase 8)
# -----------------------------------------------------------------------------
# LLM_PROVIDER : openai_compatible | anthropic
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Daily hard cap (USD) — kill switch trips on breach.
LLM_MAX_USD_PER_DAY=5
LLM_REQUEST_TIMEOUT_SECONDS=30
# Per-token rates. 0 by default for self-hosted gateways; populate from
# invoices when using a paid endpoint.
LLM_COST_PER_INPUT_TOKEN_USD=0
LLM_COST_PER_OUTPUT_TOKEN_USD=0

# -----------------------------------------------------------------------------
# Telegram (phases 11 + 13)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Whitelist stricte, ex. 123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
REDIS_URL=redis://redis:6379/0
